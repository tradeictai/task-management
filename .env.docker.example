# Copy this file to .env before running docker compose in production-like mode
# cp .env.docker.example .env

# Use a strong secret in production
JWT_SECRET=replace_with_strong_secret

# Local access from browser
NEXT_PUBLIC_API_URL=http://localhost:5001/api
FRONTEND_URL=http://localhost:3005
FRONTEND_HOST_PORT=3005

# For EC2, set these like:
# NEXT_PUBLIC_API_URL=http://<EC2_PUBLIC_IP>:5001/api
# FRONTEND_URL=http://<EC2_PUBLIC_IP>:3001
# FRONTEND_HOST_PORT=3001
